.favorites-page {
  min-height: 100vh;
  background: #F7F3EC;
  padding-bottom: 40rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3E3A35;
}

.page-count {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: #1E5631;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.product-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
}

.product-image-box {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3E3A35;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E53935;
}

.product-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.cart-btn {
  background: #E8F5E9;
  color: #1E5631;
}

.remove-btn {
  background: #FFF3E0;
  color: #E65100;
}
