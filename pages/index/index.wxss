  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
}

.coupon-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 60vh;
}

.coupon-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx 20rpx;
  border-bottom: 1rpx solid rgba(180,160,130,0.1);
}

.coupon-picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3E3A35;
}

.coupon-picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.coupon-picker-list {
  padding: 16rpx 24rpx;
  max-height: 50vh;
}

.coupon-picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #FFFDF7 0%, #FFF8EE 100%);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(180,160,130,0.12);
}

.coupon-picker-left {
  min-width: 120rpx;
  text-align: center;
  padding-right: 20rpx;
}

.coupon-picker-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #D35D47;
  display: block;
}

.coupon-picker-condition {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.coupon-picker-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(180,160,130,0.15);
  margin: 0 20rpx;
}

.coupon-picker-right {
  flex: 1;
}

.coupon-picker-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3E3A35;
}

.coupon-picker-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #DDD;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.coupon-picker-check.checked {
  background: #1E5631;
  border-color: #1E5631;
  color: #FFFFFF;
  font-size: 28rpx;
}

.coupon-picker-empty {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #BBB5AA;
}
