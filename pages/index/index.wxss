/* ========================================
   乌东苗寨小卖部 — 森系·原木风 设计系统
   自然 / 温暖 / 山野气息
   ======================================== */

/* ----- 基础 ----- */
page {
  background-color: #F7F3EC;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  color: #3E3A35;
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
}

/* ----- 骨架屏 ----- */
.home-skeleton {
  padding: 0;
}

.skeleton-banner {
  width: 100%;
  height: 36vh;
  background: linear-gradient(90deg, #E8E2D8 25%, #F0EAE0 50%, #E8E2D8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-categories {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 32rpx 24rpx;
}

.skeleton-cat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-circle {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #E8E2D8 25%, #F0EAE0 50%, #E8E2D8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #E8E2D8 25%, #F0EAE0 50%, #E8E2D8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-line.short {
  width: 60rpx;
}

.skeleton-line.medium {
  width: 180rpx;
  margin: 20rpx 28rpx;
}

.skeleton-line.long {
  width: 80%;
  margin: 12rpx 0;
}

.skeleton-section {
  padding: 0 20rpx;
}

.skeleton-products {
  display: flex;
  flex-wrap: wrap;
  padding: 0 8rpx;
}

.skeleton-product-card {
  width: 50%;
  padding: 0 8rpx 16rpx;
}

.skeleton-square {
  width: 100%;
  height: 270rpx;
  border-radius: 22rpx;
  background: linear-gradient(90deg, #E8E2D8 25%, #F0EAE0 50%, #E8E2D8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 10rpx;
}

/* ----- 页面容器 ----- */
.page-container {
  min-height: 100vh;
  padding-top: 0;
  padding-bottom: 40rpx;
}

.page-content {
  animation: leafIn 0.40s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes leafIn {
  from { opacity: 0; transform: translateY(18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 骨架屏动画 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

/* ----- 按压反馈 ----- */
.product-card:active, .recommend-item:active, .category-product-item:active,
.cart-item:active, .address-card:active, .menu-item:active,
.checkout-item:active, .payment-method-item:active {
  transform: scale(0.97);
  transition: transform 0.12s ease;
}

.category-item:active .category-icon-wrapper { transform: scale(0.90); }

/* ----- 通用商品辅助样式 ----- */
.product-emoji { display: none; }
.product-emoji-small { display: none; }
.product-emoji-thumb { display: none; }

.product-image-real {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 2;
}

/* 隐藏 emoji 占位 — 商品图已就绪 */
.home-product-emoji { display: none; }

/* ==================== 页面1: 首页 — 清新国风 ==================== */
.home-page {
  background: #FBF6EE;
  padding-bottom: 0;
}

/* 顶部大图 Banner — 全屏宽度 */
.hero-banner {
  position: relative;
  width: 100%;
  height: 36vh;
  overflow: hidden;
}

.hero-banner-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(170deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.28) 35%, rgba(0,0,0,0.55) 100%);
}

.hero-content {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 88%;
}

.hero-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-shadow:
    0 0 30rpx rgba(0,0,0,0.40),
    0 4rpx 20rpx rgba(0,0,0,0.35),
    0 8rpx 40rpx rgba(0,0,0,0.20);
  line-height: 1.25;
}

.hero-subtitle {
  font-size: 24rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.90);
  letter-spacing: 10rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.25);
  margin-top: 8rpx;
}

/* 搜索栏 — Banner 底部嵌入 */
.search-bar-home {
  position: absolute;
  bottom: 24rpx;
  left: 28rpx;
  right: 28rpx;
  padding: 0;
}

.search-bar-home-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.88);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-bar-home-icon {
  font-size: 28rpx;
  color: rgba(160,155,145,0.55);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-bar-home-input {
  flex: 1;
  font-size: 24rpx;
  color: #3E3A35;
}

.search-bar-home-btn {
  font-size: 32rpx;
  margin-left: 8rpx;
  padding: 0 8rpx;
}

.search-bar-home-placeholder {
  color: #C8C2B8;
  font-size: 24rpx;
}

.search-results {
  padding: 24rpx;
}

.search-results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-results-title {
  font-size: 26rpx;
  color: #999;
}

.search-results-clear {
  font-size: 24rpx;
  color: #1E5631;
  padding: 8rpx 20rpx;
  background: #E8F5E9;
  border-radius: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
}

.product-image-box {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3E3A35;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E53935;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

/* 分类图标 — 正圆形实拍图 */
.home-categories {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 32rpx 24rpx;
}

.home-category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-category-img-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(60,50,30,0.08);
  border: 2rpx solid rgba(255,255,255,0.80);
  transition: transform 0.2s ease;
}

.home-category-img-wrap:active {
  transform: scale(0.92);
}

.home-category-image {
  width: 100%;
  height: 100%;
}

.home-category-name {
  font-size: 24rpx;
  color: #5A5044;
  font-weight: 500;
  margin-top: 12rpx;
}

/* 中间运营 Banner — 苗寨全景 */
.second-banner {
  position: relative;
  width: calc(100% - 32rpx);
  height: 260rpx;
  margin: 0 16rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(60,50,30,0.10);
}

.second-banner-image {
  width: 100%;
  height: 100%;
}

.second-banner-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.40) 100%);
}

.second-banner-content {
  position: absolute;
  left: 28rpx;
  bottom: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.second-banner-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.25);
}

.second-banner-subtitle {
  font-size: 22rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.88);
  letter-spacing: 6rpx;
  text-shadow: 0 1rpx 8rpx rgba(0,0,0,0.20);
  margin-top: 6rpx;
  margin-bottom: 16rpx;
}

.second-banner-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 28rpx;
  background: rgba(255,255,255,0.22);
  border: 1.5rpx solid rgba(255,255,255,0.50);
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  backdrop-filter: blur(4rpx);
}

/* 服务标签 — 暖金实色圆标 */
.service-tags {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 16rpx 16rpx;
  margin: 0 16rpx 16rpx;
  background: transparent;
  border: none;
  box-shadow: none;
}

.service-tag-item {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.service-tag-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #EAD7B8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.service-tag-icon {
  width: 36rpx;
  height: 36rpx;
}

.service-tag-text {
  font-size: 22rpx;
  color: #4A4540;
  font-weight: 500;
}

/* 人气推荐 — 标题 */
.home-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 28rpx 12rpx;
}

.home-section-title-row {
  display: flex;
  align-items: center;
}

.home-section-tag {
  width: 6rpx;
  height: 28rpx;
  background: #CF8E5A;
  border-radius: 3rpx;
  margin-right: 10rpx;
}

.home-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3E3A35;
}

.home-section-more {
  font-size: 22rpx;
  color: #9B9487;
}

/* 商品卡片 — 双列 */
.home-product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx 12rpx;
}

.home-product-card {
  width: 50%;
  padding: 0 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(200,190,175,0.10);
  transition: transform 0.2s ease;
}

.home-product-card:active {
  transform: scale(0.97);
}

.home-product-img-box {
  width: 100%;
  height: 270rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.home-product-emoji {
  font-size: 80rpx;
}

.home-product-info {
  padding: 14rpx 16rpx 16rpx;
}

.home-product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3E3A35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-bottom: 12rpx;
}

.home-product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #CF5A3A;
}

.home-product-sales {
  font-size: 22rpx;
  color: #C2BEB4;
}

/* 首页滚动高度（适配底部导航） */
.home-scroll {
  height: calc(100vh - 100rpx);
}

/* 底部占位 */
.home-bottom-placeholder {
  height: 120rpx;
}

/* 底部导航栏 — 线描简约风格 */
.home-bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.04);
  border-top: 1rpx solid rgba(200,190,175,0.12);
  z-index: 100;
  padding-bottom: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.home-bottom-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 8rpx 0;
  min-width: 80rpx;
}

.home-bottom-nav-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  height: 44rpx;
}

.home-bottom-nav-icon {
  width: 44rpx;
  height: 44rpx;
  transition: opacity 0.25s ease;
}

/* 首页 — 始终绿色实色 */
.home-bottom-nav-item:first-child .home-bottom-nav-icon {
  opacity: 1;
}

.home-bottom-nav-item:first-child .home-bottom-nav-label {
  color: #1E5631;
}

/* 其余项激活时 — 绿色 */
.home-bottom-nav-item.active .home-bottom-nav-icon {
  opacity: 1;
}

.home-bottom-nav-item.active .home-bottom-nav-label {
  color: #1E5631;
  font-weight: 500;
}

.home-bottom-nav-label {
  font-size: 20rpx;
  color: #C2BEB4;
  font-weight: 400;
  transition: color 0.25s ease;
}

.home-bottom-nav-badge {
  position: absolute;
  top: 0;
  right: -4rpx;
  background: #E8574A;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 9999rpx;
  padding: 0 6rpx;
}

/* 全局底部安全区 */
.global-bottom-safe {
  height: 100rpx;
}

/* ==================== 页面2: 分类 ==================== */
.category-header {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  background: #FFFDF7;
  margin: 0 24rpx 20rpx;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
  border: 1rpx solid rgba(180,160,130,0.08);
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #3E3A35;
  letter-spacing: 4rpx;
}

.category-page {
  display: flex;
  height: calc(100vh - 320rpx);
  background: #F7F3EC;
}

.category-left {
  width: 22%;
  height: 100%;
  background: transparent;
}

.category-nav { height: 100%; }

.category-nav-item {
  position: relative;
  padding: 24rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.category-nav-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #1E5631 0%, #2D7A4A 100%);
  border-radius: 0 3rpx 3rpx 0;
}

.category-nav-text { font-size: 26rpx; color: #6B6055; font-weight: 400; }

.category-nav-item.active .category-nav-text {
  color: #1E5631;
  font-weight: 600;
  font-size: 28rpx;
}

.category-nav-item.active {
  background: #FFFDF7;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(60,50,30,0.06);
}

.category-right {
  width: 78%;
  background: #F7F3EC;
}

.category-products {
  height: 100%;
  padding: 16rpx 24rpx;
}

.category-product-list {
  display: flex;
  flex-direction: column;
}

.category-product-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #FFFDF7;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
  border: 1rpx solid rgba(180,160,130,0.08);
  transition: transform 0.2s ease;
}

.category-product-item:active {
  transform: scale(0.97);
}

.category-product-item:last-child { margin-bottom: 0; }

.category-product-image-box {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #F0EAE0;
  position: relative;
}

.category-product-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.category-product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E3A35;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-product-desc {
  font-size: 26rpx;
  color: #9B9487;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.category-product-bottom {
  display: flex;
  align-items: baseline;
}

.category-product-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #D35D47;
  margin-right: 14rpx;
}

.category-product-sales {
  font-size: 24rpx;
  color: #C2BEB4;
}

/* 分类加载骨架屏 */
.category-loading {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
}

.skeleton-product {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #FFFDF7;
  border-radius: 28rpx;
  height: 240rpx;
}

/* 分类空状态 */
.category-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.category-empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.category-empty-text {
  font-size: 28rpx;
  color: #B5AEA2;
}

.load-more-btn {
  padding: 30rpx 0;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: #1E5631;
  font-weight: 500;
}

/* ==================== 页面3: 商品详情 ==================== */
.product-detail-page { padding-bottom: 120rpx; background: #F7F3EC; }

.product-swiper { width: 100%; height: 520rpx; }

.product-detail-image-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.detail-emoji { display: none; }

.product-detail-info {
  padding: 32rpx;
  background: #FFFDF7;
  margin: 20rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
  border: 1rpx solid rgba(180,160,130,0.08);
}

.product-detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.product-detail-price {
  font-size: 52rpx;
  font-weight: 800;
  color: #D35D47;
  margin-right: 16rpx;
}

.product-detail-origin-price {
  font-size: 28rpx;
  color: #B5AEA2;
  text-decoration: line-through;
}

.product-detail-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #3E3A35;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.product-detail-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.product-tag {
  padding: 10rpx 20rpx;
  background: #E8F0E0;
  color: #1E5631;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(30,86,49,0.12);
  margin-right: 14rpx;
  margin-bottom: 14rpx;
}

.product-detail-sales-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
