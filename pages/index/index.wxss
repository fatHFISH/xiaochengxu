/* ========== 返回按钮 ========== */
.back-btn {
  position: fixed;
  top: 96rpx;
  left: 20rpx;
  z-index: 99;
  width: 68rpx;
  height: 68rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.10);
  border: 1rpx solid rgba(200,190,175,0.25);
  transition: opacity 0.2s, transform 0.15s;
}

.back-btn.hidden {
  opacity: 0;
  pointer-events: none;
}

.back-btn:active {
  transform: scale(0.92);
  background: rgba(245,242,237,0.95);
}

.back-arrow {
  font-size: 48rpx;
  color: #5A5348;
  line-height: 1;
  font-weight: 300;
  margin-top: -4rpx;
}

/* ========== 滚动视图容器 ========== */
.page-scroll {
  height: 100vh;
  overflow-y: auto;
}

.detail-scroll {
  height: calc(100vh - 220rpx);
  overflow-y: auto;
}

.cart-scroll {
  height: calc(100vh - 230rpx);
  overflow-y: auto;
}

.checkout-scroll {
  height: calc(100vh - 220rpx);
  overflow-y: auto;
}

/* 隐藏滚动条（美化） */
.page-scroll::-webkit-scrollbar,
.detail-scroll::-webkit-scrollbar,
.cart-scroll::-webkit-scrollbar,
.checkout-scroll::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

/* ========== 页面切换动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInRight {
  from { opacity: 0.6; transform: translateX(-40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.page-content.fade-in {
  animation: fadeIn 0.3s ease-out;
}

.page-content.slide-in-right {
  animation: slideInRight 0.3s ease-out;
}

