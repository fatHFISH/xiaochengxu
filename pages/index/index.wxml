  <!-- ==================== 地址编辑弹窗 ==================== -->
  <view class="address-modal-mask" wx:if="{{showAddressForm}}" bindtap="onCancelAddressForm"></view>
  <view class="address-modal" wx:if="{{showAddressForm}}">
    <view class="address-modal-header">
      <text class="address-modal-title">{{addressFormData.id ? '编辑地址' : '新增地址'}}</text>
      <text class="address-modal-close" bindtap="onCancelAddressForm">✕</text>
    </view>
    <view class="address-modal-body">
      <view class="address-form-item">
        <text class="address-form-label">收货人</text>
        <input class="address-form-input" placeholder="请输入收货人姓名" value="{{addressFormData.name}}" bindinput="onAddressFormInput" data-field="name" />
      </view>
      <view class="address-form-item">
        <text class="address-form-label">手机号</text>
        <input class="address-form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{addressFormData.phone}}" bindinput="onAddressFormInput" data-field="phone" />
      </view>
      <view class="address-form-item">
        <text class="address-form-label">省份</text>
        <input class="address-form-input" placeholder="请输入省份" value="{{addressFormData.province}}" bindinput="onAddressFormInput" data-field="province" />
      </view>
      <view class="address-form-item">
        <text class="address-form-label">城市</text>
        <input class="address-form-input" placeholder="请输入城市" value="{{addressFormData.city}}" bindinput="onAddressFormInput" data-field="city" />
      </view>
      <view class="address-form-item">
        <text class="address-form-label">区县</text>
        <input class="address-form-input" placeholder="请输入区县" value="{{addressFormData.district}}" bindinput="onAddressFormInput" data-field="district" />
      </view>
      <view class="address-form-item">
        <text class="address-form-label">详细地址</text>
        <input class="address-form-input" placeholder="请输入详细地址" value="{{addressFormData.detail}}" bindinput="onAddressFormInput" data-field="detail" />
      </view>
      <view class="address-form-item address-form-checkbox-item" bindtap="onToggleAddressDefault">
        <text class="address-form-label">设为默认地址</text>
        <view class="address-form-checkbox {{addressFormData.is_default ? 'checked' : ''}}">
          <text wx:if="{{addressFormData.is_default}}">✓</text>
        </view>
      </view>
    </view>
