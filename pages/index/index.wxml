        <view class="recommend-grid">
          <view class="recommend-item" wx:for="{{recommendProducts}}" wx:key="index" bindtap="onProductTap" data-id="{{item.id}}">
            <view class="recommend-item-image-box" style="background-color: {{item.bgColor}}">
              <text class="product-emoji">{{item.emoji}}</text>
              <image class="recommend-item-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="recommendProducts[{{index}}].image"></image>
            </view>
            <text class="recommend-item-name">{{item.name}}</text>
            <text class="recommend-item-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </view>
    </scroll-view>
  </view>

  <!-- ==================== 页面8: 个人中心 User Profile ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 7}}">
    <scroll-view class="page-scroll" scroll-y bindscroll="onPageScroll">
    <view class="profile-page">
      <!-- 顶部标题栏 -->
      <view class="profile-title-bar">
        <text class="profile-title-text">我的</text>
      </view>

      <!-- 用户信息卡片 -->
      <view class="profile-user-card">
        <view class="profile-user-left">
          <image class="profile-avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" binderror="onImageError" data-cloud="{{userInfo.avatarCloud}}" data-key="userInfo.avatar"></image>
          <view class="profile-user-text">
            <text class="profile-nickname">{{userInfo.nickname}}</text>
            <text class="profile-welcome">{{userInfo.welcome}}</text>
          </view>
        </view>
        <view class="profile-user-right">
          <text class="profile-settings-icon">⚙</text>
        </view>
      </view>

      <!-- 我的订单 -->
      <view class="profile-order-section">
        <view class="profile-order-header">
          <text class="profile-order-title">我的订单</text>
          <view class="profile-order-more" bindtap="onViewAllOrders">
            <text class="profile-order-more-text">全部订单</text>
            <text class="profile-order-arrow">›</text>
          </view>
        </view>
        <view class="profile-order-icons">
          <view class="profile-order-icon-item" wx:for="{{orderStatusItems}}" wx:key="index" bindtap="onViewOrdersByStatus" data-status="{{item.status}}">
            <view class="profile-order-icon-wrap">
              <image class="profile-order-icon" src="{{item.icon}}" mode="aspectFit"></image>
              <view class="profile-order-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</view>
            </view>
            <text class="profile-order-icon-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 菜单列表 -->
      <view class="profile-menu-section">
        <view class="profile-menu-item" wx:for="{{menuItems}}" wx:key="index" bindtap="onMenuTap" data-index="{{index}}">
          <view class="profile-menu-left">
            <image class="profile-menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
            <text class="profile-menu-name">{{item.name}}</text>
            <text class="profile-menu-badge" wx:if="{{item.id === 1 && profileFavCount > 0}}">{{profileFavCount}}</text>
            <text class="profile-menu-badge" wx:if="{{item.id === 3 && profileCouponCount > 0}}">{{profileCouponCount}}张</text>
          </view>
          <text class="profile-menu-arrow">›</text>
        </view>
      </view>

      <!-- 底部信息 -->
      <view class="profile-footer">
        <text class="profile-footer-text">乌东苗寨小卖部 v1.0</text>
      </view>
    </view>
    </scroll-view>
  </view>

  <!-- ==================== 页面9: 全部订单 Orders List ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 8}}">
    <view class="order-list-header">
      <view class="order-list-header-row">
        <text class="order-list-back-btn" bindtap="onBackFromOrders">‹ 返回</text>
        <text class="order-list-title">全部订单</text>
        <view style="width: 80rpx;"></view>
      </view>
    </view>
    <view class="orders-page">
      <!-- 状态筛选 -->
      <view class="orders-filter">
        <view class="orders-filter-item {{orderListStatus === '' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="">全部</view>
        <view class="orders-filter-item {{orderListStatus === 'pending' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="pending">待付款</view>
        <view class="orders-filter-item {{orderListStatus === 'paid' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="paid">已付款</view>
        <view class="orders-filter-item {{orderListStatus === 'shipped' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="shipped">已发货</view>
        <view class="orders-filter-item {{orderListStatus === 'delivering' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="delivering">配送中</view>
        <view class="orders-filter-item {{orderListStatus === 'completed' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="completed">已完成</view>
        <view class="orders-filter-item {{orderListStatus === 'cancelled' ? 'active' : ''}}" bindtap="onFilterOrders" data-status="cancelled">已取消</view>
      </view>

      <scroll-view class="orders-scroll" scroll-y bindscroll="onPageScroll">
      <view class="orders-list">
        <view class="orders-loading" wx:if="{{orderListLoading}}">
          <text>加载中...</text>
        </view>
        <view class="orders-empty" wx:if="{{!orderListLoading && orderList.length === 0}}">
          <text class="orders-empty-icon">📋</text>
          <text class="orders-empty-text">暂无订单</text>
        </view>
        <view class="order-card" wx:for="{{orderList}}" wx:key="index" bindtap="onViewOrderDetail" data-id="{{item._id}}">
          <view class="order-card-header">
            <text class="order-card-no">订单号: {{item.order_no}}</text>
            <text class="order-card-status">{{item.status === 'pending' ? '待付款' : item.status === 'paid' ? '已付款' : item.status === 'shipped' ? '已发货' : item.status === 'delivering' ? '配送中' : item.status === 'completed' ? '已完成' : item.status === 'cancelled' ? '已取消' : item.status}}</text>
          </view>
          <view class="order-card-items">
            <view class="order-card-item" wx:for="{{item.items || []}}" wx:key="idx" bindtap="onOrderProductTap" data-id="{{item.productId}}">
              <view class="order-card-item-image-box">
                <image class="order-card-item-image" src="{{item.image || ''}}" mode="aspectFill" binderror="onImageError" />
              </view>
              <view class="order-card-item-info">
                <text class="order-card-item-name">{{item.name}}</text>
                <view class="order-card-item-bottom">
                  <text class="order-card-item-price">¥{{item.price}}</text>
                  <text class="order-card-item-qty">x{{item.quantity}}</text>
                </view>
              </view>
            </view>
          </view>
          <view class="order-card-footer">
            <text class="order-card-total">合计: ¥{{item.total_amount}}</text>
            <text class="order-card-pay-amount" wx:if="{{item.pay_amount && item.pay_amount != item.total_amount}}">实付: ¥{{item.pay_amount}}</text>
          </view>
          <view class="order-card-actions" wx:if="{{item.status === 'pending' || item.status === 'paid' || item.status === 'shipped' || item.status === 'delivering'}}">
            <view class="order-action-btn order-action-btn-cancel" wx:if="{{item.status === 'pending'}}" bindtap="onCancelOrder" data-id="{{item._id}}">取消订单</view>
            <view class="order-action-btn order-action-btn-pay" wx:if="{{item.status === 'pending'}}" bindtap="onPayOrder" data-id="{{item._id}}">立即支付</view>
            <view class="order-action-btn order-action-btn-confirm" wx:if="{{item.status === 'shipped' || item.status === 'delivering'}}" bindtap="onConfirmReceive" data-id="{{item._id}}">确认收货</view>
          </view>
        </view>
      </view>
      <view class="load-more-btn" wx:if="{{orderListHasMore}}" bindtap="onLoadMoreOrders">
        <text class="load-more-text" wx:if="{{!orderListLoading}}">加载更多</text>
        <text class="load-more-text" wx:else>加载中...</text>
      </view>
      </scroll-view>
    </view>
  </view>

  <!-- ==================== 页面10: 订单详情 Order Detail ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 9}}">
    <view class="order-detail-page">
      <view class="order-detail-header">
        <view class="order-detail-header-row">
          <text class="order-detail-back-btn" bindtap="goBack">‹ 返回</text>
          <text class="order-detail-title">订单详情</text>
          <view style="width: 80rpx;"></view>
        </view>
      </view>

      <scroll-view class="order-detail-scroll" scroll-y bindscroll="onPageScroll">
        <view class="order-detail-loading" wx:if="{{orderDetailLoading}}">
          <text>加载中...</text>
        </view>

        <block wx:if="{{!orderDetailLoading && orderDetail}}">
          <!-- 状态卡片 -->
          <view class="order-status-card">
            <view class="order-status-icon-wrap">
              <text class="order-status-icon">{{orderDetail.status === 'completed' ? '✓' : orderDetail.status === 'cancelled' ? '✕' : orderDetail.status === 'paid' ? '●' : '○'}}</text>
            </view>
            <view class="order-status-info">
              <text class="order-status-text">{{orderDetail.status === 'pending' ? '等待付款' : orderDetail.status === 'paid' ? '已付款，等待发货' : orderDetail.status === 'shipped' ? '已发货' : orderDetail.status === 'delivering' ? '配送中' : orderDetail.status === 'completed' ? '已完成' : orderDetail.status === 'cancelled' ? '已取消' : orderDetail.status}}</text>
              <text class="order-status-desc" wx:if="{{orderDetail.status === 'pending'}}">请尽快完成支付，超时订单将自动取消</text>
              <text class="order-status-desc" wx:if="{{orderDetail.status === 'paid'}}">商家正在准备商品，请耐心等待</text>
              <text class="order-status-desc" wx:if="{{orderDetail.status === 'shipped' || orderDetail.status === 'delivering'}}">商品正在运送途中</text>
              <text class="order-status-desc" wx:if="{{orderDetail.status === 'completed'}}">感谢您的购买，欢迎再次光临</text>
              <text class="order-status-desc" wx:if="{{orderDetail.status === 'cancelled'}}">{{orderDetail.cancel_reason || '订单已取消'}}</text>
            </view>
          </view>

          <!-- 收货地址 -->
          <view class="order-detail-address" wx:if="{{orderDetail.address}}">
            <view class="order-detail-address-top">
              <text class="order-detail-address-name">{{orderDetail.address.name}}</text>
              <text class="order-detail-address-phone">{{orderDetail.address.phone}}</text>
            </view>
            <text class="order-detail-address-detail">{{orderDetail.address.province}}{{orderDetail.address.city}}{{orderDetail.address.district}}{{orderDetail.address.detail}}</text>
          </view>

          <!-- 商品列表 -->
          <view class="order-detail-items">
            <view class="order-detail-shop-row">
              <view style="width: 36rpx; height: 36rpx; background: linear-gradient(135deg, #1E5631 0%, #2D7A4A 100%); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; margin-right: 12rpx;">
                <text style="font-size: 20rpx; color: #FFFFFF; font-weight: bold;">乌</text>
              </view>
              <text style="font-size: 26rpx; font-weight: 600; color: #3E3A35;">乌东苗寨小卖部</text>
            </view>
            <view class="order-detail-item" wx:for="{{orderDetail.items}}" wx:key="idx">
              <view class="order-detail-item-image-box">
                <image class="order-detail-item-image" src="{{item.image || ''}}" mode="aspectFill" binderror="onImageError" />
              </view>
              <view class="order-detail-item-info">
                <text class="order-detail-item-name">{{item.name}}</text>
                <view class="order-detail-item-bottom">
                  <text class="order-detail-item-price">¥{{item.price}}</text>
                  <text class="order-detail-item-qty">x{{item.quantity}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 订单信息 -->
          <view class="order-detail-info-section">
            <view class="order-detail-info-row">
              <text class="order-detail-info-label">订单编号</text>
              <text class="order-detail-info-value selectable">{{orderDetail.order_no}}</text>
            </view>
            <view class="order-detail-info-row">
              <text class="order-detail-info-label">下单时间</text>
              <text class="order-detail-info-value">{{orderDetail.createdAt}}</text>
            </view>
            <view class="order-detail-info-row" wx:if="{{orderDetail.paidAt}}">
              <text class="order-detail-info-label">付款时间</text>
              <text class="order-detail-info-value">{{orderDetail.paidAt}}</text>
            </view>
            <view class="order-detail-info-row">
              <text class="order-detail-info-label">商品总额</text>
              <text class="order-detail-info-value">¥{{orderDetail.total_amount}}</text>
            </view>
            <view class="order-detail-info-row" wx:if="{{orderDetail.discount_amount > 0}}">
              <text class="order-detail-info-label">优惠减免</text>
              <text class="order-detail-info-value" style="color: #D35D47;">-¥{{orderDetail.discount_amount}}</text>
            </view>
            <view class="order-detail-info-row" style="border-bottom: none;">
              <text class="order-detail-info-label" style="font-weight: 700;">实付金额</text>
              <text class="order-detail-info-value" style="font-size: 36rpx; font-weight: 800; color: #D35D47;">¥{{orderDetail.pay_amount || orderDetail.total_amount}}</text>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="order-detail-actions" wx:if="{{orderDetail.status === 'pending' || orderDetail.status === 'paid' || orderDetail.status === 'shipped' || orderDetail.status === 'delivering' || orderDetail.status === 'completed' || orderDetail.status === 'cancelled'}}">
            <view class="order-detail-action-btn order-detail-action-cancel" wx:if="{{orderDetail.status === 'pending'}}" bindtap="onCancelOrder" data-id="{{orderDetail._id}}">取消订单</view>
            <view class="order-detail-action-btn order-detail-action-pay" wx:if="{{orderDetail.status === 'pending'}}" bindtap="onPayOrder" data-id="{{orderDetail._id}}">立即支付</view>
            <view class="order-detail-action-btn order-detail-action-confirm" wx:if="{{orderDetail.status === 'shipped' || orderDetail.status === 'delivering'}}" bindtap="onConfirmReceive" data-id="{{orderDetail._id}}">确认收货</view>
            <view class="order-detail-action-btn order-detail-action-delete-order" wx:if="{{orderDetail.status === 'cancelled' || orderDetail.status === 'completed'}}" bindtap="onDeleteOrder" data-id="{{orderDetail._id}}">删除订单</view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>
</view>

