<view class="page-container">

  <!-- 返回按钮（首页隐藏） -->
  <view class="back-btn {{currentPage === 0 || currentPage === 8 || currentPage === 9 ? 'hidden' : ''}}" bindtap="goBack">
    <text class="back-arrow">‹</text>
  </view>

  <!-- ==================== 页面1: 首页 Home ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 0}}">
    <scroll-view class="page-scroll home-scroll" scroll-y bindscroll="onPageScroll" refresher-enabled refresher-default-text="下拉刷新" refresher-refreshing="{{refreshingHome}}" bindrefresherrefresh="onRefreshHome">
    <view class="home-page">

      <!-- 骨架屏 -->
      <view class="home-skeleton" wx:if="{{loading}}">
        <view class="skeleton-banner"></view>
        <view class="skeleton-categories">
          <view class="skeleton-cat" wx:for="{{4}}" wx:key="index">
            <view class="skeleton-circle"></view>
            <view class="skeleton-line short"></view>
          </view>
        </view>
        <view class="skeleton-section">
          <view class="skeleton-line medium"></view>
          <view class="skeleton-products">
            <view class="skeleton-product-card" wx:for="{{4}}" wx:key="index">
              <view class="skeleton-square"></view>
              <view class="skeleton-line long"></view>
              <view class="skeleton-line short"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 正常内容 -->
      <block wx:if="{{!loading}}">
      <!-- 顶部大图 Banner — 全屏宽度 -->
      <view class="hero-banner">
        <image class="hero-banner-image" src="{{bannerImage}}" mode="aspectFill" binderror="onImageError"></image>
        <view class="hero-overlay"></view>
        <view class="hero-content">
          <text class="hero-title">乌东苗寨的小卖部</text>
          <text class="hero-subtitle">来自大山的自然馈赠</text>
        </view>
        <!-- 搜索栏 — Banner 底部嵌入 -->
        <view class="search-bar-home">
          <view class="search-bar-home-wrapper">
            <text class="search-bar-home-icon">☌</text>
            <input class="search-bar-home-input" value="{{searchKeyword}}" placeholder="搜索商品" placeholder-class="search-bar-home-placeholder" bindinput="onSearchInput" bindconfirm="onSearch" />
          </view>
        </view>
      </view>

      <!-- 分类图标 — 正圆形实拍图 -->
      <view class="home-categories">
        <view class="home-category-item" wx:for="{{homeCategories}}" wx:key="index" bindtap="onCategoryTap" data-id="{{item.id}}">
          <view class="home-category-img-wrap">
            <image class="home-category-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud}}" data-key="homeCategories[{{index}}].image"></image>
          </view>
          <text class="home-category-name">{{item.name}}</text>
        </view>
      </view>

      <!-- 中间运营 Banner — 苗寨全景 -->
      <view class="second-banner">
        <image class="second-banner-image" src="{{secondBannerImage}}" mode="aspectFill" binderror="onImageError"></image>
        <view class="second-banner-overlay"></view>
        <view class="second-banner-content">
          <text class="second-banner-title">乌东苗寨</text>
          <text class="second-banner-subtitle">传承与自然的味道</text>
          <view class="second-banner-btn">探索好物</view>
        </view>
      </view>

      <!-- 服务标签 — 圆形浅色图标 -->
      <view class="service-tags">
        <view class="service-tag-item" wx:for="{{serviceTags}}" wx:key="index">
          <view class="service-tag-circle"><image class="service-tag-icon" src="{{item.icon}}" mode="aspectFit"></image></view>
          <text class="service-tag-text">{{item.text}}</text>
        </view>
      </view>

      <!-- 人气推荐 -->
      <view class="home-section-header">
        <view class="home-section-title-row">
          <view class="home-section-tag"></view>
          <text class="home-section-title">人气推荐</text>
        </view>
        <text class="home-section-more">更多 ›</text>
      </view>
      <view class="home-product-grid">
        <view class="home-product-card" wx:for="{{hotProducts}}" wx:key="index" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="home-product-img-box" style="background-color: {{item.bgColor}}">
            <text class="home-product-emoji">{{item.emoji}}</text>
            <image class="product-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="hotProducts[{{index}}].image"></image>
          </view>
          <view class="home-product-info">
            <text class="home-product-name">{{item.name}}</text>
            <view class="home-product-meta">
              <text class="home-product-price">¥{{item.price}}</text>
              <text class="home-product-sales">已售{{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部占位 -->
      <view class="home-bottom-placeholder"></view>
      </block>

    </view>
    </scroll-view>
  </view>

  <!-- ==================== 页面2: 商品分类 Category ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 1}}">
    <view class="category-header">
      <text class="category-header-title">商品分类</text>
    </view>
    <view class="category-page">
      <view class="category-left">
        <scroll-view scroll-y class="category-nav">
          <view wx:for="{{categoryList}}" wx:key="index"
                class="category-nav-item {{selectedCategory === index ? 'active' : ''}}"
                bindtap="onSelectCategory" data-index="{{index}}">
            <view class="category-nav-indicator" wx:if="{{selectedCategory === index}}"></view>
            <text class="category-nav-text">{{item}}</text>
          </view>
        </scroll-view>
      </view>
      <view class="category-right">
        <scroll-view scroll-y class="category-products">
          <view class="category-product-list">
            <view class="category-product-item" wx:for="{{categoryProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
              <view class="category-product-image-box">
                <image class="product-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="categoryProducts[{{index}}].image"></image>
              </view>
              <view class="category-product-info">
                <text class="category-product-name">{{item.name}}</text>
                <text class="category-product-desc">{{item.desc}}</text>
                <view class="category-product-bottom">
                  <text class="category-product-price">¥{{item.price}}</text>
                  <text class="category-product-sales">已售{{item.sales}}</text>
                </view>
              </view>
            </view>
            <view class="category-loading" wx:if="{{categoryLoading}}">
              <view class="skeleton skeleton-product"></view>
              <view class="skeleton skeleton-product"></view>
              <view class="skeleton skeleton-product"></view>
            </view>
            <view class="category-empty" wx:if="{{categoryEmpty && !categoryLoading && !categoryHasMore}}">
              <text class="category-empty-icon">📦</text>
              <text class="category-empty-text">暂无商品</text>
            </view>
            <view class="load-more-btn" wx:if="{{categoryHasMore}}" bindtap="onLoadMoreCategory">
              <text class="load-more-text" wx:if="{{!categoryLoading}}">加载更多</text>
              <text class="load-more-text" wx:else>加载中...</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- ==================== 页面3-8 ... ==================== -->

  <!-- 底部导航栏 — 全局共享 -->
  <view class="home-bottom-nav">
    <view class="home-bottom-nav-item {{currentNavTab === index ? 'active' : ''}}" wx:for="{{homeNavTabs}}" wx:key="index" bindtap="onNavTabTap" data-index="{{index}}">
      <view class="home-bottom-nav-icon-wrap">
        <image class="home-bottom-nav-icon" src="{{item.icon}}" mode="aspectFit"></image>
      </view>
      <text class="home-bottom-nav-label">{{item.label}}</text>
      <view class="home-bottom-nav-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</view>
    </view>
  </view>

  <!-- 页面底部安全区占位 -->
  <view class="global-bottom-safe"></view>

  <!-- ==================== 页面3: 商品详情 Product Details ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 2}}">
    <view class="product-detail-page">
      <scroll-view class="detail-scroll" scroll-y bindscroll="onPageScroll">
      <swiper class="product-swiper" indicator-dots autoplay circular>
        <swiper-item wx:for="{{productDetail.images}}" wx:key="index">
          <view class="product-detail-image-box" style="background-color: {{productDetail.bgColor}}" bindtap="onPreviewImage" data-src="{{item}}">
            <text class="detail-emoji">{{productDetail.emoji}}</text>
            <image class="product-image-real" src="{{item}}" mode="aspectFill" binderror="onImageError" data-cloud="{{productDetail.imageCloud || item}}" data-key="productDetail.images[{{index}}]"></image>
          </view>
        </swiper-item>
      </swiper>

      <!-- 商品信息 -->
      <view class="product-detail-info">
        <view class="product-detail-shop-row" style="display: flex; align-items: center; margin-bottom: 16rpx;">
          <view style="width: 36rpx; height: 36rpx; background: linear-gradient(135deg, #1E5631 0%, #2D7A4A 100%); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; margin-right: 12rpx;">
            <text style="font-size: 20rpx; color: #FFFFFF; font-weight: bold;">乌</text>
          </view>
          <text style="font-size: 24rpx; color: #6B6055; font-weight: 500; margin-right: 12rpx;">乌东苗寨小卖部</text>
          <text style="font-size: 20rpx; color: #1E5631; background: #E8F5E9; padding: 4rpx 12rpx; border-radius: 9999rpx; font-weight: 500;">官方直营</text>
        </view>
        <view class="product-detail-price-row">
          <text class="product-detail-price">¥{{productDetail.price}}</text>
          <text class="product-detail-origin-price">¥{{productDetail.originalPrice}}</text>
        </view>
        <text class="product-detail-name">{{productDetail.name}}</text>
        <view class="product-detail-tags">
          <text class="product-tag" wx:for="{{productDetail.tags}}" wx:key="index">{{item}}</text>
        </view>
        <view class="product-detail-sales-row">
          <text>销量 {{productDetail.sales}}</text>
          <text>库存 {{productDetail.stock}}</text>
        </view>
      </view>

      <!-- 服务承诺 -->
      <view style="padding: 24rpx 32rpx; background: #FFFDF7; margin: 20rpx 24rpx; border-radius: 28rpx; box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05); border: 1rpx solid rgba(180,160,130,0.08);">
        <view style="display: flex; justify-content: space-around;">
          <view style="display: flex; align-items: center;">
            <text style="font-size: 28rpx; color: #1E5631; margin-right: 8rpx;">✓</text>
            <text style="font-size: 24rpx; color: #6B6055;">产地直供</text>
          </view>
          <view style="display: flex; align-items: center;">
            <text style="font-size: 28rpx; color: #1E5631; margin-right: 8rpx;">✓</text>
            <text style="font-size: 24rpx; color: #6B6055;">正品保证</text>
          </view>
          <view style="display: flex; align-items: center;">
            <text style="font-size: 28rpx; color: #1E5631; margin-right: 8rpx;">✓</text>
            <text style="font-size: 24rpx; color: #6B6055;">极速发货</text>
          </view>
        </view>
      </view>

      <view class="product-detail-desc">
        <text class="product-detail-desc-title">商品详情</text>
        <text class="product-detail-desc-content">{{productDetail.description}}</text>
      </view>

      <view class="product-detail-options">
        <view class="quantity-selector">
          <text class="quantity-label">数量</text>
          <view class="quantity-control">
            <view class="quantity-btn {{productDetail.quantity <= 1 ? 'disabled' : ''}}" bindtap="onDecreaseQuantity">-</view>
            <text class="quantity-value">{{productDetail.quantity}}</text>
            <view class="quantity-btn" bindtap="onIncreaseQuantity">+</view>
          </view>
        </view>
      </view>
      </scroll-view>

      <view class="detail-bottom-bar">
        <view class="detail-bottom-left">
          <view class="detail-bottom-icon" bindtap="onDetailCustomerService">
            <text class="icon-text">💬</text>
            <text class="icon-label">客服</text>
          </view>
          <view class="detail-bottom-icon" bindtap="onToggleFavorite">
            <text class="icon-text">{{productDetail.isFavorite ? '❤️' : '🤍'}}</text>
            <text class="icon-label">收藏</text>
          </view>
        </view>
        <view class="detail-bottom-right">
          <view class="btn-add-cart" bindtap="onAddToCart">加入购物车</view>
          <view class="btn-buy-now" bindtap="onBuyNow">立即购买</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 页面4: 购物车 Shopping Cart ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 3}}">
    <view class="cart-page">
      <view class="cart-header">
        <text class="cart-shop-name">乌东苗寨小卖部</text>
        <text class="cart-edit-btn" bindtap="onToggleEdit">{{isEditCart ? '完成' : '编辑'}}</text>
      </view>

      <scroll-view class="cart-scroll" scroll-y bindscroll="onPageScroll">

      <view class="cart-empty" wx:if="{{cartItems.length === 0}}">
        <text class="cart-empty-text">购物车是空的</text>
        <view class="cart-empty-btn" bindtap="switchPage" data-index="0">去逛逛</view>
      </view>

      <view class="cart-list" wx:else>
        <view class="cart-item" wx:for="{{cartItems}}" wx:key="index">
          <view class="cart-item-checkbox" bindtap="onToggleCartItem" data-index="{{index}}">
            <view class="checkbox-circle {{item.selected ? 'checked' : ''}}">
              <text class="checkbox-check" wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
          <view class="cart-item-img-box" style="background-color: {{item.bgColor}}">
            <image class="cart-item-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="cartItems[{{index}}].image"></image>
          </view>
          <view class="cart-item-info">
            <text class="cart-item-name">{{item.name}}</text>
            <text class="cart-item-spec">{{item.spec}}</text>
            <view class="cart-item-bottom">
              <text class="cart-item-price">¥{{item.price}}</text>
              <view class="cart-item-stepper">
                <view class="stepper-btn" bindtap="onCartDecrease" data-index="{{index}}">−</view>
                <view class="stepper-line"></view>
                <text class="stepper-num">{{item.quantity}}</text>
                <view class="stepper-line"></view>
                <view class="stepper-btn" bindtap="onCartIncrease" data-index="{{index}}">+</view>
              </view>
            </view>
          </view>
        </view>
      </view>
      </scroll-view>

      <view class="cart-footer-bar" wx:if="{{cartItems.length > 0}}">
        <view class="footer-left">
          <view class="footer-checkbox" bindtap="onToggleSelectAll">
            <view class="checkbox-circle {{isSelectAll ? 'checked' : ''}}">
              <text class="checkbox-check" wx:if="{{isSelectAll}}">✓</text>
            </view>
          </view>
          <text class="footer-select-all">全选</text>
        </view>
        <view class="footer-center" wx:if="{{!isEditCart}}">
          <text class="footer-total-label">合计:</text>
          <text class="footer-total-price">¥{{totalPrice}}</text>
        </view>
        <view class="footer-checkout-btn" wx:if="{{!isEditCart}}" bindtap="onCheckout">
          <text class="checkout-text">去结算({{selectedCount}})</text>
        </view>
        <view class="footer-delete-btn" wx:if="{{isEditCart}}" bindtap="onDeleteCartItems">
          <text class="checkout-text">删除</text>
        </view>
      </view>

      <!-- 底部导航栏 -->
      <view class="home-bottom-nav">
        <view class="home-bottom-nav-item {{currentNavTab === index ? 'active' : ''}}" wx:for="{{homeNavTabs}}" wx:key="index" bindtap="onNavTabTap" data-index="{{index}}">
          <view class="home-bottom-nav-icon-wrap">
            <image class="home-bottom-nav-icon" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <text class="home-bottom-nav-label">{{item.label}}</text>
          <view class="home-bottom-nav-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 页面5: 地址选择 Address Selection ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 4}}">
    <scroll-view class="page-scroll" scroll-y bindscroll="onPageScroll">
    <view class="address-page">
      <view class="address-header">
        <text class="address-title">选择收货地址</text>
      </view>

      <view class="address-list">
        <view class="address-card {{selectedAddressIndex === index ? 'selected' : ''}}"
              wx:for="{{addressList}}" wx:key="index"
              bindtap="onSelectAddress" data-index="{{index}}">
          <view class="address-card-left">
            <view class="address-info">
              <view class="address-user-row">
                <text class="address-user-name">{{item.name}}</text>
                <text class="address-user-phone">{{item.phone}}</text>
              </view>
              <text class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
            </view>
            <view class="address-default-tag" wx:if="{{item.is_default}}">默认</view>
          </view>
          <view class="address-card-right">
            <text class="address-edit-btn" bindtap="onEditAddress" data-index="{{index}}">编辑</text>
          </view>
        </view>
      </view>

      <view class="add-address-btn" bindtap="onAddAddress">
        <text class="add-address-icon" style="margin-right: 16rpx;">+</text>
        <text class="add-address-text">添加新地址</text>
      </view>

      <view class="order-items-section">
        <text class="order-items-title">本次下单</text>
        <scroll-view scroll-x class="order-items-scroll">
          <view class="order-items-list">
            <view class="order-item-thumb-box" wx:for="{{orderItems}}" wx:key="index" style="background-color: {{item.bgColor}}">
              <text class="product-emoji-thumb">{{item.emoji}}</text>
              <image class="order-item-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="orderItems[{{index}}].image"></image>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
    </scroll-view>

      <!-- 地址选择底部栏（来自结算流程才显示） -->
  <view class="address-footer-bar" wx:if="{{addressFromCheckout}}">
    <view class="address-footer-btn" bindtap="onProceedToCheckout">
      <text class="address-footer-text">确认地址，去支付</text>
    </view>
  </view>
  </view>

  <!-- ==================== 页面6: 确认支付订单 Checkout ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 5}}">
    <view class="checkout-page">
      <scroll-view class="checkout-scroll" scroll-y bindscroll="onPageScroll">
      <view class="checkout-address" bindtap="onCheckoutAddressTap">
        <view class="checkout-address-info">
          <text class="checkout-address-name">{{checkoutAddress.name}}</text>
          <text class="checkout-address-phone">{{checkoutAddress.phone}}</text>
          <text class="checkout-address-detail">{{checkoutAddress.province}}{{checkoutAddress.city}}{{checkoutAddress.district}}{{checkoutAddress.detail}}</text>
        </view>
        <text class="checkout-address-arrow">></text>
      </view>

      <view class="checkout-shop">
        <view style="display: flex; align-items: center;">
          <view style="width: 44rpx; height: 44rpx; background: linear-gradient(135deg, #1E5631 0%, #2D7A4A 100%); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx;">
            <text style="font-size: 22rpx; color: #FFFFFF; font-weight: bold;">乌</text>
          </view>
          <text class="checkout-shop-name" style="font-size: 28rpx; font-weight: 700; color: #3E3A35; margin-right: 16rpx;">乌东苗寨小卖部</text>
          <text style="font-size: 20rpx; color: #1E5631; background: #E8F5E9; padding: 4rpx 12rpx; border-radius: 9999rpx; font-weight: 500;">官方直营</text>
        </view>
      </view>

      <view class="checkout-items">
        <view class="checkout-item" wx:for="{{checkoutItems}}" wx:key="index">
          <view class="checkout-item-image-box" style="background-color: {{item.bgColor}}">
            <text class="product-emoji-small">{{item.emoji}}</text>
            <image class="checkout-item-image-real" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-cloud="{{item.image_cloud || item.image}}" data-key="checkoutItems[{{index}}].image"></image>
          </view>
          <view class="checkout-item-info">
            <text class="checkout-item-name">{{item.name}}</text>
            <view class="checkout-item-bottom">
              <text class="checkout-item-price">¥{{item.price}}</text>
              <text class="checkout-item-quantity">x{{item.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="checkout-fee-row">
        <text class="checkout-fee-label">运费</text>
        <text class="checkout-fee-value">¥0</text>
      </view>
      <view class="checkout-fee-row" bindtap="onToggleCouponPicker">
        <text class="checkout-fee-label">优惠券</text>
        <text class="checkout-fee-value {{selectedCoupon ? 'checkout-fee-discount' : ''}}">{{selectedCoupon ? '-¥' + selectedCoupon.value : '无'}}</text>
        <text class="checkout-address-arrow" style="margin-left: 8rpx; font-size: 24rpx;">{{selectedCoupon ? '' : '>'}}</text>
        <text wx:if="{{selectedCoupon}}" style="margin-left: 8rpx; font-size: 22rpx; color: #D35D47; padding: 2rpx 10rpx; border: 1rpx solid #D35D47; border-radius: 9999rpx;" bindtap="onRemoveSelectedCoupon" catchtap>移除</text>
      </view>

      <view class="payment-methods">
        <text class="payment-methods-title">支付方式</text>
        <view class="payment-method-item {{selectedPayment === 'wechat' ? 'selected' : ''}}" bindtap="onSelectPayment" data-method="wechat">
          <view class="payment-method-left">
            <text class="payment-method-icon">💬</text>
            <text class="payment-method-name">微信支付</text>
          </view>
          <view class="payment-method-radio {{selectedPayment === 'wechat' ? 'checked' : ''}}"><view class="radio-inner" wx:if="{{selectedPayment === 'wechat'}}"></view></view>
        </view>
        <view class="payment-method-item {{selectedPayment === 'alipay' ? 'selected' : ''}}" bindtap="onSelectPayment" data-method="alipay">
          <view class="payment-method-left">
            <text class="payment-method-icon">💙</text>
            <text class="payment-method-name">支付宝</text>
          </view>
          <view class="payment-method-radio {{selectedPayment === 'alipay' ? 'checked' : ''}}"><view class="radio-inner" wx:if="{{selectedPayment === 'alipay'}}"></view></view>
        </view>
        <view class="payment-method-item {{selectedPayment === 'bank' ? 'selected' : ''}}" bindtap="onSelectPayment" data-method="bank">
          <view class="payment-method-left">
            <text class="payment-method-icon">💳</text>
            <text class="payment-method-name">银行卡</text>
          </view>
          <view class="payment-method-radio {{selectedPayment === 'bank' ? 'checked' : ''}}"><view class="radio-inner" wx:if="{{selectedPayment === 'bank'}}"></view></view>
        </view>
      </view>
      </scroll-view>

      <!-- 优惠券选择弹窗 -->
      <view class="coupon-picker-mask" wx:if="{{showCouponPicker}}" bindtap="onToggleCouponPicker"></view>
      <view class="coupon-picker" wx:if="{{showCouponPicker}}">
        <view class="coupon-picker-header">
          <text class="coupon-picker-title">选择优惠券</text>
          <text class="coupon-picker-close" bindtap="onToggleCouponPicker">✕</text>
        </view>
        <scroll-view class="coupon-picker-list" scroll-y>
          <view class="coupon-picker-item" wx:for="{{myAvailableCoupons}}" wx:key="index" bindtap="onSelectCheckoutCoupon" data-index="{{index}}">
            <view class="coupon-picker-left">
              <text class="coupon-picker-value">¥{{item.value}}</text>
              <text class="coupon-picker-condition">满{{item.minAmount}}可用</text>
            </view>
            <view class="coupon-picker-divider"></view>
            <view class="coupon-picker-right">
              <text class="coupon-picker-name">{{item.name || '优惠券'}}</text>
            </view>
            <view class="coupon-picker-check {{selectedCoupon && (selectedCoupon._id === item._id) ? 'checked' : ''}}">
              <text wx:if="{{selectedCoupon && (selectedCoupon._id === item._id)}}">✓</text>
            </view>
          </view>
          <view class="coupon-picker-empty" wx:if="{{myAvailableCoupons.length === 0}}">
            <text>暂无可用优惠券</text>
          </view>
        </scroll-view>
      </view>

      <view class="checkout-bottom-bar">
        <view class="checkout-bottom-left">
          <text class="checkout-total-label">合计:</text>
          <text class="checkout-total-original" wx:if="{{selectedCoupon}}" style="font-size: 24rpx; color: #BBB5AA; text-decoration: line-through; margin-right: 8rpx;">¥{{checkoutTotal}}</text>
          <text class="checkout-total-price">¥{{selectedCoupon ? checkoutPayAmount : checkoutTotal}}</text>
        </view>
        <view class="checkout-bottom-right" bindtap="onSubmitOrder">
          <text class="checkout-submit-btn">立即支付</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 页面7: 支付成功 Success Page ==================== -->
  <view class="page-content {{pageTransition}}" wx:if="{{currentPage === 6}}">
    <scroll-view class="page-scroll" scroll-y bindscroll="onPageScroll">
    <view class="success-page">
      <view class="success-header">
        <view class="success-icon-wrapper">
          <icon type="success" size="60" color="#1E5631"></icon>
        </view>
        <text class="success-title">支付成功</text>
        <text class="success-order-no">订单号: {{orderNo}}</text>
        <text class="success-tip">预计 2-3 天送达</text>
      </view>

      <view class="success-btn-wrapper">
        <view class="success-btn" bindtap="onViewOrder">查看订单</view>
      </view>

      <view class="recommend-section">
