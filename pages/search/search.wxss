.search-page {
  min-height: 100vh;
  background: #F7F3EC;
  padding-bottom: 40rpx;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #1E5631;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #FFFFFF;
}

.search-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.search-clear {
  font-size: 32rpx;
  color: rgba(255,255,255,0.6);
  padding: 0 8rpx;
}

.search-cancel {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-left: 20rpx;
}

.search-section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E3A35;
}

.section-clear {
  font-size: 24rpx;
  color: #999;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-tag-wrap {
  display: inline-flex;
  align-items: center;
  background: #FFFDF7;
  border-radius: 30rpx;
  border: 1rpx solid rgba(180,160,130,0.15);
  overflow: hidden;
}

.history-tag {
  padding: 12rpx 0 12rpx 24rpx;
  font-size: 26rpx;
  color: #6B6055;
}

.history-tag-del {
  padding: 12rpx 16rpx 12rpx 8rpx;
  font-size: 22rpx;
  color: #CCC5B8;
  line-height: 1;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  padding: 12rpx 24rpx;
  background: #FFFDF7;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #6B6055;
  border: 1rpx solid rgba(180,160,130,0.15);
}

.hot-tag.hot {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  color: #E65100;
  border-color: rgba(230,81,0,0.2);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

.sort-tabs {
  display: flex;
  gap: 24rpx;
}

.sort-tab {
  font-size: 26rpx;
  color: #999;
  padding-bottom: 8rpx;
}

.sort-tab.active {
  color: #1E5631;
  font-weight: 600;
  border-bottom: 3rpx solid #1E5631;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(60,50,30,0.05);
}

.product-image-box {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3E3A35;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E53935;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC;
}
