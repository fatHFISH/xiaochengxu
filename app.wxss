/**app.wxss**/
/* ========================================
   乌东苗寨小卖部 - 全局样式
   设计系统：自然、温暖、精致
   ======================================== */

/* ----- 基础 ----- */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  color: #333333;
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
}

view, text, image, input, scroll-view {
  box-sizing: border-box;
}

/* ----- 设计令牌 ----- */
:root {
  /* 品牌色 */
  --brand: #1E5631;
  --brand-light: #E8F5E9;
  --brand-dark: #164026;
  /* 强调色 */
  --accent: #E54D42;
  --accent-light: #FFEBEE;
  /* 中性色 */
  --bg: #F5F5F5;
  --surface: #FFFFFF;
  --text: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border: #F0F0F0;
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.08);
  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;
}

/* ----- 工具类 ----- */
.brand-color { color: #1E5631; }
.brand-bg { background-color: #1E5631; }
.price-color { color: #E54D42; }
.price-bg { background-color: #E54D42; }

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ----- 卡片基础 ----- */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* ----- 按钮基础 ----- */
.btn-primary {
  background: linear-gradient(135deg, #1E5631 0%, #2D7A4A 100%);
  color: #FFFFFF;
  border-radius: 9999rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-outline {
  background: #FFFFFF;
  color: #1E5631;
  border: 2rpx solid #1E5631;
  border-radius: 9999rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
